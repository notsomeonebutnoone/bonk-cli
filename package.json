{
  "name": "bonk-cli",
  "version": "0.1.1",
  "description": "bonk any video from YouTube, X, Instagram, Threads & 1800+ sites — Premiere Pro ready, right from your terminal.",
  "type": "module",
  "bin": {
    "bonk": "dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "start": "node dist/cli.js",
    "prepack": "npm run build",
    "prepublishOnly": "npm test && npm run typecheck && npm run build"
  },
  "author": "username1221",
  "keywords": [
    "video",
    "downloader",
    "yt-dlp",
    "youtube",
    "instagram",
    "twitter",
    "threads",
    "premiere",
    "premiere-pro",
    "cli",
    "tui",
    "ink",
    "npx",
    "bonk"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "ink": "^7.1.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
